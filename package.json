{
	"name": "stylist-svelte",
	"version": "1.0.1",
	"description": "A comprehensive Svelte 5 UI component library",
	"type": "module",
	"author": "Godmy & AI-Team",
	"license": "MIT",
	"packageManager": "yarn@4.5.1",
	"keywords": [
		"svelte",
		"svelte5",
		"ui",
		"components",
		"design-system"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Godmy/stylist-svelte.git"
	},
	"bugs": {
		"url": "https://github.com/Godmy/stylist-svelte/issues"
	},
	"homepage": "https://github.com/Godmy/stylist-svelte#readme",
	"scripts": {
		"dev": "vite dev",
		"build": "yarn data:svg && svelte-package && publint",
		"ci:pipeline": "yarn lint && yarn test:unit && yarn build",
		"preview": "vite preview",
		"package": "svelte-package",
		"tsc": "tsc --noEmit",
		"prepublishOnly": "yarn data:svg && yarn build",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"validate": "yarn lint && yarn tsc && yarn check",
		"test": "vitest",
		"test:unit": "vitest run",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"clean": "node -e \"const fs=require('node:fs'); ['dist','.svelte-kit','node_modules/.vite'].forEach((path)=>fs.rmSync(path,{recursive:true,force:true}));\"",
		"audit": "yarn audit",
		"depcheck": "depcheck",
		"data:svg": "tsx scripts/data/svg/index.ts",
		"data:shader": "tsx scripts/data/shader/index.ts",
		"const:enum": "tsx scripts/const/enum/index.ts",
		"const:map": "tsx scripts/const/map/index.ts",
		"const:record": "tsx scripts/const/record/index.ts",
		"const:struct": "tsx scripts/const/struct/index.ts",
		"type:enum": "tsx scripts/type/enum/index.ts",
		"type:map": "tsx scripts/type/map/index.ts",
		"type:record": "tsx scripts/type/record/index.ts",
		"type:struct": "tsx scripts/type/struct/index.ts",
		"interface:proto": "tsx scripts/interface/proto/index.ts",
		"interface:recipe": "tsx scripts/interface/recipe/index.ts",
		"class:manager": "tsx scripts/class/manager/index.ts",
		"class:style-manager": "tsx scripts/class/style-manager/index.ts",
		"class:object-manager": "tsx scripts/class/object-manager/index.ts",
		"function:state": "tsx scripts/function/state/index.ts",
		"function:script": "tsx scripts/function/script/index.ts",
		"json:meta": "tsx scripts/json/meta/index.ts"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"!dist/chat/**",
		"!scripts/**",
		"!dist/commerce/**",
		"!dist/development/**",
		"!dist/domain/**",
		"!dist/geo/**",
		"!dist/**/*.json",
		"!dist/**/*.story.*",
		"!dist/**/index.story.svelte",
		"!dist/**/index.story.svelte.d.ts",
		"!dist/**/story-*.svelte",
		"!dist/**/story-*.svelte.d.ts",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*",
		"!dist/management/**",
		"!dist/marketing/**",
		"!dist/playground/**",
		"!dist/science/**",
		"!dist/server/**",
		"!dist/social/**"
	],
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"peerDependenciesMeta": {
		"zod": {
			"optional": true
		}
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.43.2",
		"@sveltejs/package": "^2.3.10",
		"@sveltejs/vite-plugin-svelte": "^6.2.0",
		"@testing-library/svelte": "^5.2.8",
		"@types/node": "^22.0.0",
		"@vitest/coverage-v8": "^3.2.4",
		"autoprefixer": "^10.4.21",
		"baseline-browser-mapping": "^2.9.19",
		"depcheck": "^1.4.7",
		"eslint": "^9.36.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.4",
		"jsdom": "^29.0.1",
		"madge": "^8.0.0",
		"postcss": "^8.4.49",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"publint": "^0.3.15",
		"svelte": "^5.39.5",
		"svelte-check": "^4.3.2",
		"svelte-preprocess": "^6.0.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.44.1",
		"vite": "^7.1.7",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"marked": "^17.0.0",
		"shiki": "^3.15.0"
	},
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts"
}
